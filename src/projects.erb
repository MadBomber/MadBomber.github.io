---
permalink: /projects.json
sitemap: false
exclude_from_search: true
---
<%= raw site.data.projects.map { |p|
  {
    id: "project-#{p.repo_name}",
    title: p.name,
    url: "/projects/",
    content: [p.description, p.gem_name, p.language].compact.join(" "),
    collection: "projects",
    github_url: p.github_url,
    docs_url: p.docs_url,
    downloads: p.downloads,
    gem_name: p.gem_name,
    gem_version: p.gem_version
  }
}.to_json %>
